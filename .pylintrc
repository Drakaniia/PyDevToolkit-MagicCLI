[MASTER]
ignore=tests,docs,scripts
jobs=1

[MESSAGES CONTROL]
disable=
    missing-docstring,
    too-few-public-methods,
    too-many-arguments,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    line-too-long

[FORMAT]
max-line-length=120

[BASIC]
good-names=i,j,k,ex,_,e,f,fp

[DESIGN]
max-attributes=10
